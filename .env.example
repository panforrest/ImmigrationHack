# =====================================================
# ImmigrationHack — Environment Variables (template)
# Copy this file to `.env.local` and fill in real keys.
# NEVER commit `.env.local` (already in .gitignore).
# =====================================================

# ---- Featherless.ai (sponsor) ---------------------------------
# Powers all AI surfaces: parsing, scoring, drafting, chat
# Get key: https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ---- Tavily (sponsor) -----------------------------------------
# Web search for AI agents — USCIS news, RFE trends, employer history
# Get key: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ---- Alai (sponsor, optional) ---------------------------------
# Generate the immigrant's advocacy / pitch deck
ALAI_API_KEY=your_alai_api_key_here

# ---- App config ----------------------------------------------
NEXT_PUBLIC_APP_NAME=ImmigrationHack
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Optional: OpenAI fallback (if Featherless is rate-limited)
OPENAI_API_KEY=
